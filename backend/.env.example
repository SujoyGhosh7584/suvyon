# ==========================================================
# Suvyon Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------

APP_NAME=Suvyon
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=False

# ----------------------------------------------------------
# API
# ----------------------------------------------------------

API_V1_PREFIX=/api/v1

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------

SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_SECRET

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30

REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------

DATABASE_URL=postgresql://username:password@localhost:5432/suvyon

# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------

SUPABASE_URL=https://your-project.supabase.co

SUPABASE_KEY=your_supabase_anon_or_service_key

# ----------------------------------------------------------
# AI Providers
# ----------------------------------------------------------

OPENROUTER_API_KEY=

GROQ_API_KEY=

GEMINI_API_KEY=

# ----------------------------------------------------------
# Email (SMTP)
# ----------------------------------------------------------

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_USERNAME=

SMTP_PASSWORD=

SMTP_FROM_EMAIL=

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------

BACKEND_CORS_ORIGINS=["http://localhost:3000","https://localhost:3000"]